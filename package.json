{
  "name": "your-site-backend",
  "version": "1.0.0",
  "description": "Your Site GraphQL API with MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed:users": "ts-node src/scripts/seedUsers.ts",
    "seed:roles": "ts-node src/scripts/seedRoles.ts"
  },
  "keywords": [
    "graphql",
    "apollo",
    "mongodb",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.19.0",
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "graphql": "^16.12.0",
    "graphql-scalars": "^1.25.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.11",
    "@vercel/node": "^3.0.21",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
