{
  "buildCommand": "pnpm build",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/**/*.js"
    }
  },
  "rewrites": [
    {
      "source": "/graphql",
      "destination": "/api/graphql"
    },
    {
      "source": "/(.*)",
      "destination": "/api/graphql"
    }
  ]
}
