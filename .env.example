# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Configuration
PORT=5000

# JWT Configuration (REQUIRED - Generate secure random strings)
JWT_ACCESS_SECRET=your-secure-access-token-secret-here
JWT_REFRESH_SECRET=your-secure-refresh-token-secret-here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# GraphQL Configuration
GRAPHQL_PATH=/graphql

# SMTP Configuration (Required for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@bumiresources.com

# Internal API Secret (Required - all requests must include this in x-api-key header)
INTERNAL_API_SECRET=your-secure-api-secret-here

FRONTEND_URL=http://localhost:3000
NODE_ENV=development
